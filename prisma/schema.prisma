  badgeEn        String   @default("Why Us?")
  
  // Main Title
  titleAr        String   @default("لماذا تختار سما للخدمات اللوجستية؟")
  titleEn        String   @default("Why Choose SAMA Logistics?")
  
  // Description
  descriptionAr  String   @default("نحن لسنا مجرد شركة شحن، بل شريكك الاستراتيجي الذي يفهم احتياجات عملك ويعمل على تلبيتها بأعلى معايير الجودة والكفاءة.")
  descriptionEn  String   @default("We are not just a shipping company, but your strategic partner who understands your business needs and works to meet them with the highest standards of quality and efficiency.")
  
  // Reasons/Features (JSON Array)
  // Format: [{"ar": "خبرة تمتد لأكثر من 25 عاماً", "en": "Over 25 years of experience"}, ...]
  reasonsJson    String   @default("[{\"ar\":\"خبرة تمتد لأكثر من 25 عاماً\",\"en\":\"Over 25 years of experience\"},{\"ar\":\"شبكة شركاء عالمية موثوقة\",\"en\":\"Trusted global partner network\"},{\"ar\":\"أسعار تنافسية وشفافة\",\"en\":\"Competitive and transparent pricing\"},{\"ar\":\"دعم فني على مدار الساعة\",\"en\":\"24/7 technical support\"},{\"ar\":\"حلول مخصصة لكل عميل\",\"en\":\"Customized solutions for every client\"},{\"ar\":\"تتبع الشحنات في الوقت الفعلي\",\"en\":\"Real-time shipment tracking\"}]")
  
  // Images Gallery (Relation)
  images         AboutWhyImage[]
  
  // Floating Stats Card
  statsValue     String   @default("25+")
  statsLabelAr   String   @default("سنة من التميز")
  statsLabelEn   String   @default("Years of Excellence")
  
  updatedAt      DateTime @updatedAt
}

// About Why Section Images
// Recommended dimensions: 800×600 pixels (4:3) - Max: 2MB
model AboutWhyImage {
  id        String   @id @default(cuid())
  url       String   // Image path
  order     Int      @default(0)
  
  sectionId String   @default("default")
  section   AboutWhySection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========================================
// Services Page — Dynamic Sections
// ========================================

// Capability Stats Bar (e.g. "15+ Trucks", "3 Ports", "60 Tons")
model ServicesPageStat {
  id        String   @id @default(cuid())
  icon      String   @default("Truck")       // lucide-react icon name
  valueAr   String                            // "15+"
  valueEn   String
  labelAr   String                            // "شاحنة ثقيلة"
  labelEn   String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order, isActive])
}

// Fleet Showcase (Mercedes Actros, Volvo FH500, etc.)
model FleetTruck {
  id        String   @id @default(cuid())
  nameAr    String
  nameEn    String
  image     String?                           // Uploaded via dashboard
  descAr    String   @default("")
  descEn    String   @default("")
  specsJson String   @default("[]")           // JSON: [{labelAr, labelEn, valueAr, valueEn}]
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order, isActive])
}

// Port Operations (Port Said, East Port Said, Damietta)
model PortOperation {
  id        String   @id @default(cuid())
  nameAr    String
  nameEn    String
  image     String?
  descAr    String   @default("")
  descEn    String   @default("")
  factsJson String   @default("[]")           // JSON: [{ar, en}]
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order, isActive])
}

// Specialized Cargo Types (Marble, Container, Heavy Cargo)
model SpecializedCargo {
  id        String   @id @default(cuid())
  icon      String   @default("Package")      // lucide-react icon name
  titleAr   String
  titleEn   String
  badgeAr   String   @default("")
  badgeEn   String   @default("")
  descAr    String   @default("")
  descEn    String   @default("")
  gradient  String   @default("from-sky-500 to-blue-600")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order, isActive])
}

// ========================================
// Blog Page Hero Section
// ========================================

model BlogHeroSettings {
  id            String   @id @default("default")

  // Visual Effects
  blurAmount    Int      @default(0)          // Backdrop blur: 0-20px
  overlayOpacity Int     @default(75)         // Overlay color opacity: 0-100%
  overlayColor  String   @default("marine")   // Preset: 'marine', 'black', 'orange'
  showGrid      Boolean  @default(true)       // Toggle grid pattern

  // Typography Settings
  titleFontSize      String   @default("text-5xl")
  titleFontWeight    String   @default("font-bold")
  titleColor         String   @default("#ffffff")
  subtitleColor      String   @default("#ffffffcc")  // white/80
  badgeColor         String   @default("#F97316")
  highlightColor     String   @default("#F97316")
  titleFontFamilyAr  String   @default("font-cairo")
  titleFontFamilyEn  String   @default("font-inter")

  // Highlight Words
  highlightWordsAr  String   @default("")  // Comma-separated words to highlight (Arabic)
  highlightWordsEn  String   @default("")  // Comma-separated words to highlight (English)

  // Content - Arabic
  titleAr       String   @default("آخر الأخبار والمقالات")
  subtitleAr    String   @default("تابع أحدث أخبار الشحن، اتجاهات السوق، ونصائح الخبراء لتعزيز سلسلة الإمداد الخاصة بك.")
  badgeAr       String   @default("المدونة والأخبار")

  // Content - English
  titleEn       String   @default("Latest News & Articles")
  subtitleEn    String   @default("Stay updated with the latest shipping news, market trends, and expert tips to optimize your supply chain.")
  badgeEn       String   @default("Blog & News")

  // Background Image (optional, fallback if no slides)
  image         String?

  // Layout Controls
  articleLayout String   @default("grid")    // "grid" or "list"
  cardSize      String   @default("medium")  // "small", "medium", "large"

  updatedAt     DateTime @updatedAt
}

model BlogHeroSlide {
  id             String   @id @default(cuid())
  imageDesktopAr String?  @default("")  // Desktop image for Arabic (1920x1080)
  imageDesktopEn String?  @default("")  // Desktop image for English (1920x1080)
  imageMobile    String?  @default("")  // Mobile image (750x1334) - Universal
  order          Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive, order])
}

// ========================================
// Enterprise Media Library (Unlink Architecture)
// ========================================

model Media {
  id        String       @id @default(cuid())
  url       String
  fileName  String?
  mimeType  String?
  size      Int?
  width     Int?
  height    Int?
  createdAt DateTime     @default(now())
  usages    MediaUsage[]

  @@index([url])
}

model MediaUsage {
  id       String  @id @default(cuid())
  mediaId  String
  entity   String  // hero, blog, milestone, service, team, career
  entityId String
  media    Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([mediaId, entity, entityId])
  @@index([entityId])
}

// ========================================
// Accreditations & Memberships (Direct Upload)
// ========================================

model Accreditation {
  id        String   @id @default(cuid())
  logo      String   // مسار الصورة /images/accreditations/xxx.png
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order, isActive])
}

// ========================================
// Odoo ERP Integration Settings
// ========================================

model OdooSettings {
  id        String   @id @default("default")
  url       String   @default("")
  database  String   @default("")
  username  String   @default("")
  password  String   @default("")
  isActive  Boolean  @default(true)
  
  updatedAt DateTime @updatedAt
}
