# ================================
# SAMA Logistics — Environment Variables
# Copy this file to .env and fill in the values
# ================================

# ── Database ──
DATABASE_URL="file:./dev.db"
# For PostgreSQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/sama_logistics?schema=public"

# ── JWT Secret ──
# IMPORTANT: Change this in production! Use a long random string (min 32 chars)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# ── Odoo ERP Integration ──
ODOO_URL="https://your-odoo-instance.odoo.com"
ODOO_DB="your-odoo-db"
ODOO_USERNAME="your-odoo-username"
ODOO_PASSWORD="your-odoo-password"

# ── Application ──
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NODE_ENV="development"

# ── File Storage ──
# Leave empty for default (./public/images). Set for persistent volumes in production.
UPLOAD_DIR=""
